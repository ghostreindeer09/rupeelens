# Copy this file to .env and fill in real values.
# NEVER commit the real .env file — it is already in .gitignore.

# --- Database ---
DATABASE_URL=postgresql://user:pass@localhost:5432/rupeelens

# --- Auth ---
JWT_SECRET=                     # generate: openssl rand -base64 48
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# --- Token encryption (Gmail OAuth tokens at rest) ---
# Must be exactly 32 bytes, hex-encoded (64 hex chars).
# generate: openssl rand -hex 32
ENCRYPTION_KEY=

# --- AI categorisation fallback (free tier for now) ---
# Get a free key at https://console.groq.com/keys — no credit card required.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Swap to Anthropic later by setting AI_PROVIDER=anthropic and adding ANTHROPIC_API_KEY.
AI_PROVIDER=groq
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Cron / internal sync auth (separate from user JWT) ---
# generate: openssl rand -base64 32
CRON_SHARED_SECRET=

# --- CORS ---
# Comma-separated list of allowed origins. Defaults to Vite dev server.
CORS_ORIGIN=http://localhost:5173

# --- Server ---
PORT=3000
NODE_ENV=development
